<%- include('./partials/header') %>

<% if (locals.success && success.length > 0) { %>
<div class="fixed top-20 left-1/2 -translate-x-1/2 z-50 px-5 py-3 rounded-md bg-blue-500 text-white shadow-lg">
    <%= success %>
</div>
<% } %>
<% if (locals.error && error.length > 0) { %>
<div class="fixed top-20 left-1/2 -translate-x-1/2 z-50 px-5 py-3 rounded-md bg-red-500 text-white shadow-lg">
    <%= error %>
</div>
<% } %>

<div class="w-full min-h-screen px-10 py-10">
    <h2 class="text-3xl font-light text-zinc-700 mb-8">Your Cart
        <span class="text-sm text-zinc-400 ml-2">(<%= user.cart.length %> item<%= user.cart.length !== 1 ? 's' : '' %>)</span>
    </h2>

    <% if (!user.cart || user.cart.length === 0) { %>
    <div class="flex flex-col items-center justify-center h-64 text-zinc-400 gap-4">
        <i class="ri-shopping-cart-line text-6xl"></i>
        <p class="text-xl">Your cart is empty</p>
        <a href="/shop" class="px-6 py-2 bg-blue-500 text-white rounded-full text-sm hover:bg-blue-600 transition">Continue Shopping</a>
    </div>
    <% } else { %>
    <div class="flex gap-10">

        <div class="w-[60%] flex flex-col gap-5">
            <% user.cart.forEach(function(item) { %>
            <div class="flex gap-5 rounded-xl overflow-hidden shadow-sm border border-zinc-100">
               
                <div class="w-44 h-40 flex-shrink-0 flex items-center justify-center" style="background-color: <%= item.bgcolor %>;">
                    <img class="h-32 object-contain"
                        src="data:image/jpeg;base64,<%= item.image.toString('base64') %>"
                        alt="<%= item.name %>">
                </div>

                <div class="flex-1 py-5 pr-5 flex flex-col justify-between">
                    <div>
                        <h3 class="text-lg font-medium text-zinc-800"><%= item.name %></h3>
                        <div class="flex items-center gap-3 mt-1">
                            <span class="text-blue-600 font-semibold">₹ <%= item.price - item.discount %></span>
                            <% if (item.discount > 0) { %>
                            <span class="text-sm line-through text-zinc-400">₹ <%= item.price %></span>
                            <span class="text-xs text-green-600 bg-green-50 px-2 py-0.5 rounded-full">
                                <%= Math.round((item.discount / item.price) * 100) %>% OFF
                            </span>
                            <% } %>
                        </div>
                    </div>
                    <a href="/removefromcart/<%= item._id %>"
                        class="w-fit flex items-center gap-1 text-sm text-red-400 hover:text-red-600 transition mt-3">
                        <i class="ri-delete-bin-line"></i> Remove
                    </a>
                </div>
            </div>
            <% }) %>
        </div>

        <div class="w-[40%]">
            <div class="bg-zinc-50 rounded-xl border border-zinc-200 p-6 sticky top-24">
                <h3 class="text-lg font-semibold text-zinc-700 mb-5">Price Breakdown</h3>

                <%
                    let subtotal = 0;
                    let totalDiscount = 0;
                    user.cart.forEach(function(item) {
                        subtotal += Number(item.price);
                        totalDiscount += Number(item.discount);
                    });
                    let platformFee = 20;
                    let finalTotal = subtotal - totalDiscount + platformFee;
                %>

                <div class="flex flex-col gap-3 text-sm text-zinc-600">
                    <div class="flex justify-between">
                        <span>Total MRP (<%= user.cart.length %> items)</span>
                        <span>₹ <%= subtotal %></span>
                    </div>
                    <div class="flex justify-between text-green-600">
                        <span>Discount on MRP</span>
                        <span>- ₹ <%= totalDiscount %></span>
                    </div>
                    <div class="flex justify-between">
                        <span>Platform Fee</span>
                        <span>₹ <%= platformFee %></span>
                    </div>
                    <div class="flex justify-between">
                        <span>Shipping Fee</span>
                        <span class="text-green-600 font-medium">FREE</span>
                    </div>
                </div>

                <div class="w-full h-px bg-zinc-200 my-4"></div>

                <div class="flex justify-between text-lg font-semibold text-zinc-800 mb-6">
                    <span>Total Amount</span>
                    <span class="text-blue-600">₹ <%= finalTotal %></span>
                </div>

                <button
                    class="w-full py-3 bg-blue-500 hover:bg-blue-600 text-white rounded-full font-medium transition text-sm">
                    Proceed to Checkout
                </button>
                <a href="/shop"
                    class="block text-center mt-3 text-sm text-zinc-400 hover:text-zinc-600 transition">
                    Continue Shopping
                </a>
            </div>
        </div>

    </div>
    <% } %>
</div>

<%- include('./partials/footer') %>
