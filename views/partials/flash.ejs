<% if (locals.success && success.length > 0) { %>
<div id="flash-success" class="fixed top-20 left-1/2 -translate-x-1/2 z-50 px-6 py-3 rounded-lg bg-green-500 text-white shadow-lg text-sm font-medium">
    <%= success %>
</div>
<% } %>

<% if (locals.error && error.length > 0) { %>
<div id="flash-error" class="fixed top-20 left-1/2 -translate-x-1/2 z-50 px-6 py-3 rounded-lg bg-red-500 text-white shadow-lg text-sm font-medium">
    <%= error %>
</div>
<% } %>

<script>
    (function () {
        function hideFlash(id) {
            var el = document.getElementById(id);
            if (!el) return;

            var opacity = 1;
            var interval = setInterval(function () {
                opacity -= 0.05;
                el.style.opacity = opacity;
                if (opacity <= 0) {
                    clearInterval(interval);
                    el.style.display = 'none';
                }
            }, 25);
        }

        setTimeout(function () { hideFlash('flash-success'); }, 3000);
        setTimeout(function () { hideFlash('flash-error'); }, 3000);
    })();
</script> 