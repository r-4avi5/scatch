<%- include('./partials/header') %>

<div class="w-full min-h-screen flex">

    <% if (locals.error && error.length > 0) { %>
    <div class="fixed top-20 left-1/2 -translate-x-1/2 z-50 px-5 py-3 rounded-md bg-red-500 text-white shadow-lg">
        <%= error %>
    </div>
    <% } %>
    <% if (locals.success && success.length > 0) { %>
    <div class="fixed top-20 left-1/2 -translate-x-1/2 z-50 px-5 py-3 rounded-md bg-green-500 text-white shadow-lg">
        <%= success %>
    </div>
    <% } %>


    <div class="w-1/2 flex items-center justify-center min-h-screen border-r border-zinc-100">
        <div class="w-full px-16 max-w-md">
            <h3 class="text-4xl font-light mb-1">Welcome to <span class="text-blue-500 font-semibold">Scatch</span></h3>
            <h4 class="text-xl text-zinc-400 mb-8">Create your account</h4>
            <form autocomplete="off" action="/users/register" method="post" class="flex flex-col gap-4">
                <input
                    class="bg-zinc-100 px-4 py-3 border border-zinc-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-300 text-sm"
                    type="text" placeholder="Full Name" name="fullname" required>
                <input
                    class="bg-zinc-100 px-4 py-3 border border-zinc-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-300 text-sm"
                    type="email" placeholder="Email" name="email" required>
                <input
                    class="bg-zinc-100 px-4 py-3 border border-zinc-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-300 text-sm"
                    type="password" placeholder="Password (min 6 characters)" name="password" required minlength="6">
                <button
                    class="px-6 py-3 mt-1 bg-blue-500 hover:bg-blue-600 text-white rounded-full font-medium transition text-sm w-fit"
                    type="submit">Create My Account</button>
            </form>
        </div>
    </div>

    <div class="w-1/2 flex items-center justify-center min-h-screen bg-zinc-50">
        <div class="w-full px-16 max-w-md">
            <h4 class="text-xl text-zinc-400 mb-2">Already have an account?</h4>
            <h3 class="text-3xl font-light mb-8">Login</h3>
            <form autocomplete="off" action="/users/login" method="post" class="flex flex-col gap-4">
                <input
                    class="bg-white px-4 py-3 border border-zinc-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-300 text-sm"
                    type="email" placeholder="Email" name="email" required>
                <input
                    class="bg-white px-4 py-3 border border-zinc-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-300 text-sm"
                    type="password" placeholder="Password" name="password" required>
                <button
                    class="px-6 py-3 mt-1 bg-zinc-800 hover:bg-zinc-900 text-white rounded-full font-medium transition text-sm w-fit"
                    type="submit">Login</button>
            </form>
        </div>
    </div>

</div>

<%- include('./partials/footer') %>
